<svg width="480" height="340" viewBox="0 0 480 340" role="img" xmlns="http://www.w3.org/2000/svg">
  <title>High Blossom Glass diamond shapes</title>
  <desc>Two horizontally offset rounded-corner diamonds in gray and crimson</desc>

  <style>
    @keyframes score {
      to { stroke-dashoffset: 0; }
    }
    @keyframes glint {
      0%   { opacity: 0;   stroke-dashoffset: 340; }
      20%  { opacity: 1; }
      80%  { opacity: 0.7; }
      100% { opacity: 0;   stroke-dashoffset: -340; }
    }
    .d-gray {
      fill: none;
      stroke: #a8a8a8;
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 1020;
      stroke-dashoffset: 1020;
      animation: score 1.4s cubic-bezier(0.77,0,0.18,1) 0.1s infinite;
    }
    .d-red {
      fill: none;
      stroke: #b01828;
      stroke-width: 4;
      stroke-linecap: round;
      stroke-linejoin: round;
      stroke-dasharray: 1020;
      stroke-dashoffset: 1020;
      animation: score 1.4s cubic-bezier(0.77,0,0.18,1) 0.6s infinite;
    }
    #glint-line {
      fill: none;
      stroke: white;
      stroke-width: 16;
      stroke-linecap: round;
      stroke-dasharray: 340;
      stroke-dashoffset: 340;
      opacity: 0;
      animation: glint 0.5s ease-in-out 1.82s infinite;
    }
  </style>

  <defs>
    <clipPath id="hb-clip">
      <rect x="40" y="10" width="400" height="320"/>
    </clipPath>
  </defs>

  <!-- Gray diamond -->
  <path class="d-gray" d="
    M 207,33
    A 16,16 0 0 1 229,33
    L 345,159
    A 16,16 0 0 1 345,181
    L 229,307
    A 16,16 0 0 1 207,307
    L 91,181
    A 16,16 0 0 1 91,159
    Z
  "/>

  <!-- Red diamond -->
  <path class="d-red" d="
    M 251,33
    A 16,16 0 0 1 273,33
    L 389,159
    A 16,16 0 0 1 389,181
    L 273,307
    A 16,16 0 0 1 251,307
    L 135,181
    A 16,16 0 0 1 135,159
    Z
  "/>

  <!-- Glint sweep -->
  <g clip-path="url(#hb-clip)">
    <line id="glint-line" x1="155" y1="310" x2="325" y2="50"/>
  </g>

</svg>
